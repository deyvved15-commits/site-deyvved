generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
}

model User {
  id                  String            @id @default(cuid())
  name                String
  email               String            @unique
  password            String?
  role                Role              @default(STUDENT)
  phone               String?
  church              String?
  bio                 String?
  avatar              String?
  active              Boolean           @default(true)
  affiliateCode       String?           @unique
  affiliatePercentage Float?
  referredBy          String?
  walletBalance       Float             @default(0)
  lastLoginAt         DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  accounts            Account[]
  certificates        Certificate[]
  comments            Comment[]
  taughtCourses       CourseTeacher[]
  enrollments         Enrollment[]
  progress            LessonProgress[]
  ratings             LessonRating[]
  liveAttendance      LiveAttendance[]
  liveMessages        LiveMessage[]
  liveMutes           LiveMute[]
  payments            Payment[]
  sessions            Session[]
  tickets             Ticket[]
  ticketMessages      TicketMessage[]
  achievements        UserAchievement[]
  earnings            TeacherEarning[]
  referralsMade       Referral[]
  walletHistory       WalletTransaction[]
  notifications       Notification[]
  productPurchases    ProductPurchase[]
  bookmarks           LessonBookmark[]
  pushSubscriptions   PushSubscription[]
  affiliateClicks     AffiliateClick[]
  activityLogs        ActivityLog[]
}

model Course {
  id                   String        @id @default(cuid())
  title                String
  slug                 String        @unique
  description          String?
  thumbnail            String?
  published            Boolean       @default(false)
  price                Float?
  paymentType          PaymentType   @default(ONE_TIME)
  order                Int           @default(0)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  category             String?
  difficulty           String?       // BEGINNER | INTERMEDIATE | ADVANCED
  estimatedHours       Int?
  hasCertificate       Boolean       @default(false)
  certificateBg        String?       // URL da imagem de fundo
  certificatePrimaryColor String?    // Cor principal (ex: #C9A97A)
  certificateSecondaryColor String?  // Cor secundária
  certificateCustomText String?      // Texto personalizado (ex: "concluiu com aproveitamento...")
  certificateLayout    Json?          // Array de LayoutElement com posição/estilo de cada campo
  affiliatePercentage  Float         @default(0)
  salesHeadline        String?
  learningOutcomes     String[]
  targetAudience       String?
  teacherBio           String?
  certificates         Certificate[]
  teachers             CourseTeacher[]
  enrollments          Enrollment[]
  modules              Module[]
  payments             Payment[]
  tickets              Ticket[]
  referrals            Referral[]
}

model CourseTeacher {
  id                   String @id @default(cuid())
  courseId             String
  teacherId            String
  commissionPercentage Float  @default(0)

  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher User   @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([courseId, teacherId])
}

model Certificate {
  id       String   @id @default(cuid())
  userId   String
  courseId String
  issuedAt DateTime @default(now())
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model Module {
  id                   String   @id @default(cuid())
  title                String
  description          String?
  thumbnail            String?
  order                Int      @default(0)
  courseId             String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  lessons              Lesson[]
  isBonus              Boolean  @default(false)
  // Controle de lançamento
  releaseAfterDays     Int?     // libera X dias após matrícula (null = imediato)
  releaseAfterModuleId String?  // libera quando este módulo for concluído
  course               Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  releaseAfterModule   Module?  @relation("ModuleRelease", fields: [releaseAfterModuleId], references: [id], onDelete: SetNull)
  dependentModules     Module[] @relation("ModuleRelease")
}

model Lesson {
  id               String           @id @default(cuid())
  title            String
  description      String?
  content          String?
  youtubeUrl       String
  duration         String?
  order            Int              @default(0)
  releaseAfterDays Int              @default(0)
  isFree           Boolean          @default(false)
  moduleId         String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  attachments      Json?            @default("[]")
  comments         Comment[]
  module           Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress         LessonProgress[]
  ratings          LessonRating[]
  bookmarks        LessonBookmark[]
}

model LessonRating {
  id        String   @id @default(cuid())
  lessonId  String
  userId    String
  rating    Int
  feedback  String?
  createdAt DateTime @default(now())
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model Enrollment {
  id        String    @id @default(cuid())
  userId    String
  courseId  String
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  course    Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model LessonProgress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model Payment {
  id               String   @id @default(cuid())
  userId           String
  courseId         String?
  productId        String?
  couponId         String?
  amount           Float
  walletUsed       Float    @default(0)
  method           String   @default("MERCADO_PAGO") // "MERCADO_PAGO" ou "WALLET"
  status           String   @default("pending")
  statusDetail     String?
  mpPaymentId      String?
  mpPreferenceId   String?
  externalReference String?  @unique // ID da preferência ou ref externa
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  commissionAmount Float?
  course           Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  product          Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon           Coupon?          @relation(fields: [couponId], references: [id], onDelete: SetNull)
  teacherEarnings  TeacherEarning[]
}

model Comment {
  id        String   @id @default(cuid())
  lessonId  String
  userId    String
  body      String
  createdAt DateTime @default(now())
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Ticket {
  id        String          @id @default(cuid())
  userId    String
  subject   String
  status    String          @default("open")
  priority  String          @default("medium")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId  String?
  course    Course?         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  messages  TicketMessage[]
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  userId    String
  body      String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Achievement {
  id          String            @id @default(cuid())
  title       String
  description String
  icon        String
  type        String
  createdAt   DateTime          @default(now())
  users       UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  awardedAt     DateTime    @default(now())
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
}

model WeeklyLesson {
  id         String   @id @default("weekly")
  youtubeUrl String   @default("")
  content    String?
  updatedAt  DateTime @updatedAt
}

model LiveSession {
  id         String        @id @default(cuid())
  title      String
  roomName   String
  youtubeUrl String?
  active     Boolean       @default(true)
  createdAt  DateTime      @default(now())
  endedAt    DateTime?
  messages   LiveMessage[]
}

model LiveMessage {
  id        String      @id @default(cuid())
  sessionId String
  userId    String
  text      String      @db.Text
  pinned    Boolean     @default(false)
  deleted   Boolean     @default(false)
  isAnnouncement Boolean @default(false)
  createdAt DateTime    @default(now())
  session   LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LiveMute {
  id         String   @id @default(cuid())
  userId     String
  sessionId  String
  mutedUntil DateTime
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sessionId])
}

model LiveAttendance {
  id       String   @id @default(cuid())
  userId   String
  date     String
  joinedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

enum Role {
  ADMIN
  STUDENT
  TEACHER
}

enum PaymentType {
  ONE_TIME
  MONTHLY
}

model TeacherEarning {
  id        String   @id @default(cuid())
  teacherId String
  paymentId String
  amount    Float
  createdAt DateTime @default(now())

  teacher User    @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
}

model Referral {
  id         String   @id @default(cuid())
  referrerId String
  buyerId    String
  courseId   String?
  productId  String?
  paymentId  String?  @unique
  amount     Float
  status     String   @default("pending")
  createdAt  DateTime @default(now())

  referrer   User     @relation(fields: [referrerId], references: [id], onDelete: Cascade)
  course     Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model WalletTransaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Float
  type        String
  description String
  referralId  String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Coupon {
  id            String       @id @default(cuid())
  code          String       @unique
  discountType  DiscountType @default(PERCENTAGE)
  discountValue Float
  maxUses       Int?
  usedCount     Int          @default(0)
  expiresAt     DateTime?
  active        Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  payments      Payment[]
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   // "NEW_LESSON", "SUPPORT_REPLY", "SYSTEM"
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Product {
  id            String            @id @default(cuid())
  title         String
  description   String?
  price         Float
  type          ProductType       @default(EBOOK)
  thumbnail     String?
  fileUrl       String?
  published     Boolean           @default(false)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  // Campos para produtos físicos (PRINTED)
  weightG        Int?             // peso em gramas
  heightCm       Int?             // altura em cm
  widthCm        Int?             // largura em cm
  lengthCm       Int?             // comprimento em cm
  productionDays Int?             // dias úteis de produção antes do envio
  purchases     ProductPurchase[]
  payments      Payment[]
}

model ProductPurchase {
  id              String    @id @default(cuid())
  userId          String
  productId       String
  amount          Float
  createdAt       DateTime  @default(now())
  // Entrega física
  shippingName    String?
  shippingCep     String?
  shippingAddress String?
  shippingCity    String?
  shippingState   String?
  shippingService String?   // ex: "SEDEX", "PAC", "JT Express"
  shippingPrice   Float?
  shippingDays    Int?
  trackingCode    String?
  shippingStatus  String?   @default("pending") // pending | shipped | delivered
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

enum ProductType {
  EBOOK
  FILE
  AUDIO
  VIDEO
  PRINTED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

model AffiliateClick {
  id         String   @id @default(cuid())
  referrerId String
  courseSlug String?
  createdAt  DateTime @default(now())
  referrer   User     @relation(fields: [referrerId], references: [id], onDelete: Cascade)
}

model LessonBookmark {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  note      String?
  createdAt DateTime @default(now())
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id        String       @id @default(cuid())
  userId    String
  type      ActivityType
  metadata  String?
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ActivityType {
  LOGIN
  WEEKLY_LESSON
  LIVE_VIEW
  LESSON_VIEW
  LESSON_COMPLETE
  PURCHASE
  PAYMENT_FAILED
}

model SiteConfig {
  id           String   @id @default("singleton")
  pixelMeta    String?
  pixelGtm     String?
  pixelGa      String?
  pixelCustom  String?
  updatedAt    DateTime @updatedAt
}
