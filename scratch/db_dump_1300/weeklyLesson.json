    "youtubeUrl": "https://youtu.be/pjXhWRjkbBw",
    "content": "<!DOCTYPE html>\n<html lang=\"pt-BR\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no\">\n    <title>Restauração de Pedro - Estudo</title>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/chart.js\"></script>\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap\" rel=\"stylesheet\">\n    <style>\n        :root { --paper: #fafaf9; --ink: #1c1917; --amber-primary: #b45309; }\n        \n        body { \n            font-family: 'Inter', sans-serif; \n            font-size: 16px; \n            background-color: var(--paper); \n            color: var(--ink); \n            -webkit-tap-highlight-color: transparent;\n            min-height: 100vh;\n        }\n        \n        /* Títulos limitados a no máximo 20px */\n        h1, h2, h3, h4 { font-size: 20px !important; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; }\n\n        .no-scrollbar::-webkit-scrollbar { display: none; }\n        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }\n\n        .tab-content { display: none; animation: slideUp 0.4s ease-out; }\n        .tab-content.active { display: block; }\n        @keyframes slideUp { from { opacity: 0; transform: translateY(15px); } to { opacity: 1; transform: translateY(0); } }\n\n        .chart-container { position: relative; width: 100%; height: 260px; margin: 15px 0; }\n\n        .pb-safe { padding-bottom: env(safe-area-inset-bottom); }\n        .pt-safe { padding-top: env(safe-area-inset-top); }\n\n        .nav-btn.active { border-bottom: 4px solid var(--amber-primary); color: var(--amber-primary); font-weight: 800; }\n        \n        /* Containers sem scroll interno */\n        .content-card { background: white; border-radius: 16px; border: 1px solid #e7e5e4; padding: 20px; margin-bottom: 15px; }\n\n        .reveal-box { overflow: hidden; max-height: 0; transition: max-height 0.4s ease-out; }\n        .reveal-box.open { max-height: 1000px; }\n    </style>\n</head>\n<body class=\"flex flex-col\">\n\n    <header class=\"bg-stone-900 text-white p-5 pt-safe shadow-lg\">\n        <h1 class=\"text-white leading-tight\">Restauração de Pedro</h1>\n        <p class=\"text-[10px] text-stone-400 font-bold tracking-widest uppercase mt-1\">Análise de João 21</p>\n    </header>\n\n    <nav class=\"sticky top-0 bg-white border-b overflow-x-auto no-scrollbar flex z-50\">\n        <button onclick=\"switchTab('dialogo')\" id=\"tab-dialogo\" class=\"nav-btn flex-none px-5 py-4 text-[12px] font-bold uppercase active\">💬 Diálogo</button>\n        <button onclick=\"switchTab('rebanho')\" id=\"tab-rebanho\" class=\"nav-btn flex-none px-5 py-4 text-[12px] font-bold uppercase\">🐑 Rebanho</button>\n        <button onclick=\"switchTab('lideranca')\" id=\"tab-lideranca\" class=\"nav-btn flex-none px-5 py-4 text-[12px] font-bold uppercase\">👑 Liderança</button>\n    </nav>\n\n    <main class=\"p-4 pb-safe flex-1\">\n        \n        <section id=\"content-dialogo\" class=\"tab-content active\">\n            <h2 class=\"text-stone-900 mb-4\">Os Níveis do Amor</h2>\n            <div class=\"content-card bg-stone-100 border-l-4 border-amber-600 mb-6\">\n                <p class=\"text-[15px] leading-relaxed\">Jesus faz três perguntas para confrontar as três negações, descendo do amor divino (Ágape) ao afeto humano (Phileo) para restaurar Pedro.</p>\n            </div>\n\n            <div class=\"space-y-3\">\n                <div class=\"content-card p-0 overflow-hidden\">\n                    <button onclick=\"toggleReveal('rev-1')\" class=\"w-full p-4 flex justify-between items-center bg-white\">\n                        <span class=\"text-[14px] font-bold\">1ª: \"Tu me amas (Agapas)?\"</span>\n                        <span id=\"icon-rev-1\" class=\"text-amber-600 font-bold\">＋</span>\n                    </button>\n                    <div id=\"rev-1\" class=\"reveal-box px-4 bg-stone-50\">\n                        <div class=\"py-4 space-y-4\">\n                            <p class=\"text-[13px] italic\">Jesus pede amor sacrificial. Pedro responde apenas com afeto fraternal.</p>\n                            <div class=\"p-3 bg-stone-800 text-amber-400 rounded text-[14px]\">\n                                <b>Missão:</b> \"Apascenta os meus cordeiros\" (Líderes).\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"content-card p-0 overflow-hidden\">\n                    <button onclick=\"toggleReveal('rev-3')\" class=\"w-full p-4 flex justify-between items-center bg-white\">\n                        <span class=\"text-[14px] font-bold\">3ª: \"Tens afeto (Phileis)?\"</span>\n                        <span id=\"icon-rev-3\" class=\"text-amber-600 font-bold\">＋</span>\n                    </button>\n                    <div id=\"rev-3\" class=\"reveal-box px-4 bg-stone-50\">\n                        <div class=\"py-4 space-y-4\">\n                            <p class=\"text-[13px] italic text-green-700 font-bold\">A grande virada: Jesus desce ao nível de Pedro para não perdê-lo.</p>\n                            <div class=\"p-3 bg-stone-800 text-amber-400 rounded text-[14px]\">\n                                <b>Missão:</b> \"Apascenta as minhas ovelhas\". Jesus aceita o amor imperfeito.\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        <section id=\"content-rebanho\" class=\"tab-content\">\n            <h2 class=\"text-stone-900 mb-4\">A Proporção do Ministério</h2>\n            <div class=\"content-card\">\n                <div class=\"chart-container\">\n                    <canvas id=\"flockChart\"></canvas>\n                </div>\n                <div class=\"grid grid-cols-1 gap-2 mt-4\">\n                    <div class=\"p-3 bg-stone-100 rounded-lg flex items-center gap-3\">\n                        <span class=\"text-xl\">🐏</span>\n                        <p class=\"text-[13px]\"><b>120 Cordeiros:</b> Liderança (Pentecostes).</p>\n                    </div>\n                    <div class=\"p-3 bg-stone-100 rounded-lg flex items-center gap-3\">\n                        <span class=\"text-xl\">🌍</span>\n                        <p class=\"text-[13px]\"><b>5.000 Ovelhas:</b> O rebanho total ganho.</p>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        <section id=\"content-lideranca\" class=\"tab-content\">\n            <h2 class=\"text-stone-900 mb-4\">Maturidade e Perfil</h2>\n            \n            <div class=\"grid grid-cols-2 gap-2 mb-6\">\n                <div class=\"content-card text-center bg-amber-50 border-amber-200\">\n                    <span class=\"text-2xl block mb-1\">🔥</span>\n                    <b class=\"text-[11px] uppercase\">Pedro</b>\n                    <p class=\"text-[11px] text-stone-500 mt-1\">Impulso necessário para começar.</p>\n                </div>\n                <div class=\"content-card text-center bg-blue-50 border-blue-200\">\n                    <span class=\"text-2xl block mb-1\">🕊️</span>\n                    <b class=\"text-[11px] uppercase\">João</b>\n                    <p class=\"text-[11px] text-stone-500 mt-1\">O amor maduro e calmo.</p>\n                </div>\n            </div>\n\n            <div class=\"content-card bg-stone-900 text-white\">\n                <h3 class=\"text-amber-500 text-[16px] mb-3\">Fases do Obreiro</h3>\n                <div class=\"space-y-4\">\n                    <div class=\"border-l-2 border-amber-500 pl-3\">\n                        <p class=\"text-[14px] font-bold uppercase\">Juventude</p>\n                        <p class=\"text-[13px] text-stone-400\">\"Tu te cingias\". Vaidade, autonomia e o desejo de andar por onde quer.</p>\n                    </div>\n                    <div class=\"border-l-2 border-green-500 pl-3\">\n                        <p class=\"text-[14px] font-bold uppercase\">Velhice (Maturidade)</p>\n                        <p class=\"text-[13px] text-stone-400\">\"Estenderás as mãos\". Dependência de Deus e submissão à missão.</p>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n    </main>\n\n    <script>\n        function switchTab(tabId) {\n            document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));\n            document.querySelectorAll('.nav-btn').forEach(el => el.classList.remove('active'));\n            document.getElementById(`content-${tabId}`).classList.add('active');\n            document.getElementById(`tab-${tabId}`).classList.add('active');\n            \n            if (tabId === 'rebanho') initChart();\n            window.scrollTo({top: 0, behavior: 'smooth'});\n        }\n\n        function toggleReveal(id) {\n            const el = document.getElementById(id);\n            const icon = document.getElementById('icon-' + id);\n            el.classList.toggle('open');\n            icon.innerText = el.classList.contains('open') ? '－' : '＋';\n        }\n\n        let chartInstance = null;\n        function initChart() {\n            const ctx = document.getElementById('flockChart').getContext('2d');\n            if (chartInstance) chartInstance.destroy();\n            chartInstance = new Chart(ctx, {\n                type: 'doughnut',\n                data: {\n                    labels: ['Cordeiros', 'Ovelhas (Israel)', 'Ovelhas (Gentios)'],\n                    datasets: [{\n                        data: [120, 3000, 2000],\n                        backgroundColor: ['#d97706', '#44403c', '#a8a29e'],\n                        borderWidth: 2\n                    }]\n                },\n                options: {\n                    responsive: true,\n                    maintainAspectRatio: false,\n                    plugins: { \n                        legend: { position: 'bottom', labels: { font: { size: 12 } } } \n                    },\n                    cutout: '70%'\n                }\n            });\n        }\n\n        window.onload = () => switchTab('dialogo');\n    </script>\n</body>\n</html>",
